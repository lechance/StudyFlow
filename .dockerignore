.env
.env.*
!.env.example

# Documentation
*.md
!README.md

# Docker files (not needed in image)
Dockerfile
docker-compose*.yml
.dockerignore

# Agent files
AGENTS.md
.coze

# TypeScript build info
tsconfig.tsbuildinfo
*.tsbuildinfo

# Test files
__tests__
*.test.*
*.spec.*
coverage
